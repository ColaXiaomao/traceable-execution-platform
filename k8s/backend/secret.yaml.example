apiVersion: v1
kind: Secret
metadata:
  name: backend-secret
# stringData 可以直接写明文，K8s 会自动 base64 编码后存储
# 注意：secret.yaml 不应该提交到 git（加进 .gitignore）
# 生产环境应使用 Vault / Sealed Secrets / External Secrets Operator 等方案管理
type: Opaque
stringData:
  # ==== Database ====
  DATABASE_URL: "postgresql+asyncpg://traceable_user:traceable_pass@postgres:5432/traceable_db"
  SYNC_DATABASE_URL: "postgresql+psycopg://traceable_user:traceable_pass@postgres:5432/traceable_db"

  # ==== Security (Sensitive) ====
  SECRET_KEY: ""
  LITELLM_MASTER_KEY: ""

  # ==== MinIO ====
  # 和 minio/secret.yaml 里的 MINIO_ROOT_USER / MINIO_ROOT_PASSWORD 保持一致
  MINIO_ACCESS_KEY: ""
  MINIO_SECRET_KEY: ""
